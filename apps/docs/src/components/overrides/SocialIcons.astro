---
import config from 'virtual:starlight/user-config';

const links = config.social || [];
const githubSvg = '<svg viewBox="0 0 16 16" fill="currentColor" width="1em" height="1em"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>';
---

<div class="social-icons-wrapper">
	<a href="https://codeformers.it/" target="_blank" rel="noopener" class="codeformers-link sl-flex">
		<span class="codeformers-text">Projekt wspierany przez</span>
		<img src="/codeformers-logo.png" alt="CodeFormers.it" class="codeformers-img" />
	</a>
	{
		links.length > 0 && (
			<div class="social-divider" />
		)
	}
	{
		links.map(({ label, href }) => (
			<a {href} rel="me" class="sl-flex social-link">
				<span class="sr-only">{label}</span>
				<Fragment set:html={githubSvg} />
			</a>
		))
	}
</div>

<style>
	@layer starlight.core {
		.social-icons-wrapper {
			display: flex;
			align-items: center;
			gap: 0.5rem;
		}
		.codeformers-link {
			display: flex;
			align-items: center;
			gap: 0.4rem;
			text-decoration: none;
			opacity: 0.6;
			transition: opacity 0.15s;
			padding: 0.25rem 0;
		}
		.codeformers-link:hover {
			opacity: 1;
		}
		.codeformers-text {
			font-size: 0.7rem;
			color: var(--sl-color-gray-3);
			white-space: nowrap;
		}
		.codeformers-img {
			height: 18px;
			width: auto;
		}
		.social-divider {
			width: 1px;
			height: 1.2rem;
			background: var(--sl-color-gray-5);
			margin: 0 0.25rem;
		}
		.social-link {
			color: var(--sl-color-text-accent);
			padding: 0.5em;
			margin: -0.5em;
		}
		.social-link:hover {
			opacity: 0.66;
		}
		@media (max-width: 50rem) {
			.codeformers-text {
				display: none;
			}
			.social-divider {
				display: none;
			}
		}
	}
</style>
