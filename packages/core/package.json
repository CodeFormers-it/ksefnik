{
  "name": "@ksefnik/core",
  "version": "0.1.0",
  "description": "Core SDK for the Ksefnik KSeF reconciliation engine (Polish e-Invoice matching)",
  "license": "MIT",
  "author": "CodeFormers",
  "homepage": "https://ksefnik.pl",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeFormers-it/ksefnik.git",
    "directory": "packages/core"
  },
  "keywords": [
    "ksef",
    "ksefnik",
    "ksef-sdk",
    "ksef-api",
    "ksef-2",
    "ksef-node",
    "e-invoice",
    "einvoice",
    "e-faktura",
    "faktura",
    "poland",
    "polish",
    "krajowy-system-e-faktur",
    "ministry-of-finance",
    "mf",
    "invoice",
    "typescript",
    "nodejs",
    "sdk",
    "reconciliation",
    "invoice-reconciliation",
    "bank-statement",
    "mt940",
    "mbank",
    "ing",
    "pko",
    "santander",
    "fuzzy-matching",
    "fuzzball",
    "fintech",
    "accounting"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/*.test.*",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
