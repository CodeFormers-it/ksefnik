  "dependencies": {
    "@ksefnik/shared": "workspace:^",
    "zod": "^3.24",
    "mt940js": "^1.3",
    "fuzzball": "^2.1",
    "better-sqlite3": "^11.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6",
    "@types/node": "^22",
    "typescript": "^5.7"
  }
}
